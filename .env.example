# Copy to .env and replace credentials for non-local environments.

# Host-side data and API settings.
INTELLIBASKET_SOURCE_WORKBOOK=../online+retail+ii/online_retail_II.xlsx
INTELLIBASKET_PREPARED_CSV=data/processed/online_retail_ii.csv
INTELLIBASKET_PROFILE_JSON=outputs/source_profile.json
INTELLIBASKET_HDFS_SOURCE_DIR=/data/intellibasket/ods/online_retail_ii
INTELLIBASKET_HIVE_DATABASE=intellibasket
INTELLIBASKET_API_HOST=127.0.0.1
INTELLIBASKET_API_PORT=8000
INTELLIBASKET_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# Docker Compose settings.
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=intellibasket
MYSQL_USER=intellibasket
MYSQL_PASSWORD=change-me
MYSQL_PORT=3307
API_PORT=8000
WEB_PORT=8080
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# Host-side serving database connection.
INTELLIBASKET_MYSQL_URL=mysql+pymysql://intellibasket:change-me@localhost:3307/intellibasket
